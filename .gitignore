*.wbpj
*.wbpz
dp0/
user_files/
progress_files/
*.lock

# ANSYS Meshing / ICEM CFD
*.msh
*.cmdb
*.agdb
*.fmd

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/

# Distribution / packaging
dist/
build/
*.egg-info/

